# MERaLiON-3 served via a Transformers OpenAI-compatible shim (no vLLM yet).
# NGC PyTorch base ships CUDA + PyTorch for amd64 and arm64/sbsa (GB10).
ARG BASE=nvcr.io/nvidia/pytorch:24.10-py3
FROM ${BASE}

RUN pip install --no-cache-dir \
    "transformers>=4.46" accelerate soundfile fastapi "uvicorn[standard]" \
    pydantic && pip install --no-cache-dir flash-attn --no-build-isolation || true

COPY meralion_shim.py /meralion_shim.py

EXPOSE 8003
CMD ["python", "/meralion_shim.py"]
