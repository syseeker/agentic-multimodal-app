# NVIDIA Canary ASR served via a NeMo OpenAI-compatible shim (A/B vs MERaLiON).
# NeMo container ships the ASR stack for amd64 and arm64/sbsa.
ARG BASE=nvcr.io/nvidia/nemo:24.09
FROM ${BASE}

RUN pip install --no-cache-dir fastapi "uvicorn[standard]" pydantic

COPY canary_shim.py /canary_shim.py

EXPOSE 8004
CMD ["python", "/canary_shim.py"]
