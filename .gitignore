# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
.eggs/
.pytest_cache/
.ruff_cache/
*.egg-info/

# Env / secrets
.env
.env.*
!.env.example
*.bkp
*.local

# Data & model artifacts (downloaded / generated, not committed)
data/raw/
data/generated/
data/cache/
models/
*.safetensors
*.gguf

# data-designer parquet artifacts — large binary, regenerate via data/sim/forensic_cases.py
data/sim/artifacts/

# Case media — generated in future phases (sim-case-audio, images, video)
# Text files and metadata.json ARE committed; only large media is excluded.
data/cases/*/audio/*
data/cases/*/images/*
data/cases/*/video/*
!data/cases/*/audio/.gitkeep
!data/cases/*/images/.gitkeep
!data/cases/*/video/.gitkeep

# Node / UI
ui/node_modules/
ui/.svelte-kit/
ui/build/

# Cloned NVIDIA blueprints (skills clone these at deploy time; never vendored)
external/

# Misc
.DS_Store
*.log
benchmark/results/

# Phase 4 audio pipeline test/generated artifacts
data/audio/test_audio.wav
data/cases/*/audio_analysis.txt
data/cases/*/audio/*_transcript.txt
data/cases/*/_norm_*.wav
