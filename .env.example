# ─────────────────────────────────────────────────────────────────────────────
# SINGLE SOURCE OF TRUTH for shared secrets/config across ALL NVIDIA components.
# Copy to `.env`, fill in, then `deploy/propagate_env.sh <component>/deploy/.env`
# distributes the shared keys into each component's own .env (AI-Q, RAG-BP, VSS…).
# `.env` is git-ignored. Never commit real keys.
# ─────────────────────────────────────────────────────────────────────────────

# Shared credentials (needed by multiple components)
NVIDIA_API_KEY=        # hosted NIMs (dev) — air-gapped prod self-hosts instead
NGC_API_KEY=           # NGC image/model pulls
HF_TOKEN=              # gated Hugging Face checkpoints (e.g. MERaLiON)

# Harmonized stack identity (keeps us isolated from any other AI-Q/VSS on the host)
COMPOSE_PROJECT_NAME=amms

# Host ports for the harmonized stack (avoid 8000/3000/5432 if already taken)
AIQ_PORT=8100          # AI-Q deep-research sub-agent (:8100 -> container 8000)
