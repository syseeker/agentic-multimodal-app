# ──────────────────────────────────────────────────────────────────────────
# Agentic Multimodal App — environment configuration
# Copy to `.env` and adjust. Never commit `.env`.
# ──────────────────────────────────────────────────────────────────────────

# --- Hardware profile -------------------------------------------------------
# rtx6000 = dev box (RTX PRO 6000 Blackwell, 96GB, x86_64)
# gb10    = deploy target (GB10 / DGX Spark, 128GB unified, arm64/sbsa)
GPU_PROFILE=rtx6000

# --- NVIDIA / model registry -----------------------------------------------
# Needed only if you pull NIM containers or gated HF weights.
NGC_API_KEY=
HF_TOKEN=

# --- Model tags -------------------------------------------------------------
# Verified picks (mid-2026). Prefer READY quantized checkpoints over running
# ModelOpt yourself. See docs/MODELS.md for sources, NVFP4 alts, and caveats.
#
# TEXT: official FP8 (dense, safe on Blackwell). NVFP4 alt: RedHatAI/Qwen3-14B-NVFP4
TEXT_MODEL=Qwen/Qwen3-14B-FP8
TEXT_QUANT=fp8
# VLM: official FP8 (needs vLLM >= 0.11.1 + qwen-vl-utils==0.0.14)
VLM_MODEL=Qwen/Qwen3-VL-8B-Instruct-FP8
VLM_QUANT=fp8
# AUDIO: MERaLiON-3 (default) — ASR + paralinguistics across English, Singlish,
# Chinese + SEA langs (NOT Singlish-only). No vLLM yet, no quant -> Transformers
# shim (serving/meralion_shim.py), bf16.
AUDIO_MODEL=MERaLiON/MERaLiON-3-10B
AUDIO_QUANT=bf16
AUDIO_BACKEND=transformers   # transformers (shim) | vllm (once supported)
# Alternative NVIDIA ASR for A/B comparison (ASR-only, no paralinguistics).
# Enable with: docker compose --profile asr-compare up  -> serves on :8004.
ASR_ALT_MODEL=nvidia/canary-1b-v2   # or nvidia/canary-qwen-2.5b (English SoTA)

MAX_MODEL_LEN=16384

# --- Serving endpoints (OpenAI-compatible) ----------------------------------
TEXT_BASE_URL=http://serving-text:8001/v1
VLM_BASE_URL=http://serving-vlm:8002/v1
AUDIO_BASE_URL=http://serving-audio:8003/v1
SERVING_API_KEY=local-dev-key

# --- Data stores ------------------------------------------------------------
FALKORDB_HOST=falkordb
FALKORDB_PORT=6379
MILVUS_URI=http://milvus:19530
# Vector backend: milvus (GPU/cuVS) | chroma (no-GPU dev fallback)
VECTOR_BACKEND=milvus
CHROMA_PATH=/data/chroma

# --- Agent engine -----------------------------------------------------------
# deepagents (primary) | hermes (alt, P1)
AGENT_ENGINE=deepagents
AGENT_CONFIG=app/config/config_sherlock.yml

# --- App / UI ---------------------------------------------------------------
APP_PORT=8000
UI_PORT=5173

# --- Observability (P1) -----------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=http://phoenix:6006/v1/traces
ENABLE_TRACING=false
